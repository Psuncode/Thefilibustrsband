---
import { homepageContent } from "../../data/homepage";
---

<section class="border-b border-black/10 bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-[1.1fr_0.9fr] md:px-6 md:py-16">
    <div class="order-2 flex flex-col justify-center md:order-1">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">The Filibusters</p>
      <h1 class="mt-3 max-w-xl text-4xl font-black uppercase leading-none md:text-6xl">
        {homepageContent.hero.headline}
      </h1>
      <p class="mt-4 max-w-xl text-base leading-7 text-[var(--color-muted)] md:text-lg">
        {homepageContent.hero.subheadline}
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="focus-ring inline-flex min-h-11 items-center justify-center rounded-none bg-[var(--color-pink)] px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:brightness-110" href={homepageContent.hero.primaryCta.href}>
          {homepageContent.hero.primaryCta.label}
        </a>
        <a class="focus-ring inline-flex min-h-11 items-center justify-center border border-[var(--color-ink)] px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)] transition hover:bg-[var(--color-yellow)]" href={homepageContent.hero.secondaryCta.href}>
          {homepageContent.hero.secondaryCta.label}
        </a>
      </div>
    </div>
    <div class="order-1 md:order-2">
      <img
        class="aspect-[4/5] w-full object-cover shadow-[var(--shadow-poster)]"
        src="/images/hero-band.jpg"
        alt="The Filibusters posing together in a candid black-and-white band photo."
        width="1200"
        height="1500"
      />
    </div>
  </div>
</section>
