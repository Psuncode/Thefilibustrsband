---
import { homepageContent } from "../../data/homepage";

// Inline homepage signup posts to the same /api/subscribe route as the modal.
// If a legacy PUBLIC_COMMUNITY_FORM_ACTION is still set we use it as the
// form's native action (no-JS fallback); JS intercepts and uses fetch.
const legacyFormAction = import.meta.env.PUBLIC_COMMUNITY_FORM_ACTION;
const formAction = legacyFormAction || "/api/subscribe";
---

<section id="community" class="anchor-section bg-white">
  <div class="mx-auto max-w-4xl px-4 py-10 md:px-6 md:py-16">
    <div class="poster-frame rounded-[1.75rem] bg-yellow p-5 md:rounded-[2rem] md:p-10">
      <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-pink md:text-sm">Community</p>
      <h2 class="display-face mt-3 text-[2rem] uppercase leading-[0.95] tracking-[-0.03em] md:text-5xl">
        {homepageContent.community.title}
      </h2>
      <p class="mt-3 max-w-2xl text-[0.98rem] leading-6 text-ink/80 md:mt-4 md:text-base md:leading-7">
        {homepageContent.community.description}
      </p>
      <div class="mt-5 grid gap-2.5 sm:flex sm:flex-wrap sm:gap-3">
        <a
          class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-ink px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-pink"
          href={homepageContent.community.updatesHref}
        >
          {homepageContent.community.updatesCtaLabel}
        </a>
        <button
          class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-ink bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
          data-subscribe-open
          type="button"
        >
          {homepageContent.community.subscribeCtaLabel}
        </button>
      </div>
      <form
        class="mt-5 flex flex-col gap-3 md:mt-6 md:flex-row"
        action={formAction}
        method="POST"
        data-subscribe-form
      >
        <div class="flex-1">
          <label class="mb-2 block text-sm font-semibold" for="community-email">Email address</label>
          <input
            class="min-h-11 w-full rounded-full border border-ink bg-white px-4 py-3 text-base text-ink"
            id="community-email"
            name="email"
            type="email"
            autocomplete="email"
            required
          />
        </div>
        <button
          class="focus-ring min-h-11 self-end rounded-full bg-ink px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-pink disabled:opacity-70"
          type="submit"
          data-subscribe-submit
        >
          Join the community
        </button>
      </form>
      <p
        class="mt-3 text-sm leading-5 text-ink/85"
        data-subscribe-status
        hidden
        role="status"
        aria-live="polite"
      ></p>
    </div>
  </div>
</section>
