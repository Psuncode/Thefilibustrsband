---
import { homepageContent } from "../../data/homepage";

const formAction = import.meta.env.PUBLIC_COMMUNITY_FORM_ACTION;
---

<section id="community" class="bg-white">
  <div class="mx-auto max-w-4xl px-4 py-12 md:px-6 md:py-16">
    <div class="border-2 border-[var(--color-ink)] bg-[var(--color-yellow)] p-6 md:p-10">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">Community</p>
      <h2 class="mt-3 text-3xl font-black uppercase leading-none md:text-5xl">
        {homepageContent.community.title}
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--color-ink)]/80">
        {homepageContent.community.description}
      </p>
      <form class="mt-6 flex flex-col gap-3 md:flex-row" action={formAction} method="POST">
        <label class="sr-only" for="email">Email address</label>
        <input
          class="min-h-11 flex-1 border border-[var(--color-ink)] bg-white px-4 py-3 text-base text-[var(--color-ink)]"
          id="email"
          name="email"
          type="email"
          placeholder="Email address"
          autocomplete="email"
          required
        />
        <button class="focus-ring min-h-11 bg-[var(--color-ink)] px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-[var(--color-pink)]" type="submit">
          Join the community
        </button>
      </form>
    </div>
  </div>
</section>
