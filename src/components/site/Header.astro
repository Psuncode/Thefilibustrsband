---
import { Image } from "astro:assets";
import filibustersLogoText from "../../assets/images/filibusters-logo-text.png";
import { primaryNav } from "../../data/site";
---

<header class="sticky top-0 z-30 px-4 pt-2 md:px-6 md:pt-4">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-2 rounded-[1.45rem] border border-white/50 bg-white/68 px-2.5 py-2 shadow-[0_14px_30px_rgba(35,31,32,0.08)] backdrop-blur-xl md:gap-4 md:rounded-[1.6rem] md:px-5 md:py-3">
    <a class="focus-ring inline-flex shrink-0 items-center rounded-full" aria-label="Home" href="/">
      <Image
        alt="The Filibusters"
        class="h-9 w-auto md:h-16"
        height="96"
        loading="eager"
        src={filibustersLogoText}
        width="320"
      />
    </a>

    <nav aria-label="Primary" class="flex min-w-0 flex-1 items-center gap-1 rounded-[1rem] border border-black/8 bg-white/70 p-1 md:w-auto md:flex-none md:gap-2 md:rounded-full md:p-1.5">
      {primaryNav.map((item) => (
        <a
          class="focus-ring min-w-0 flex-1 rounded-full px-1.5 py-2 text-center text-[0.63rem] font-semibold uppercase tracking-[0.01em] text-[var(--color-ink)]/72 transition hover:bg-[var(--color-ink)] hover:text-white md:flex-none md:px-4 md:text-sm md:tracking-[0.08em] md:normal-case"
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
