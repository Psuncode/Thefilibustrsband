---
import { Image } from "astro:assets";
import filibustersLogoText from "../../assets/images/filibusters-logo-text.png";
import { iconPaths, primaryNav } from "../../data/site";
---

<header class="sticky top-0 z-30 px-4 pt-3 md:px-6 md:pt-4">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 rounded-[1.6rem] border border-white/55 bg-white/72 px-4 py-3 shadow-[0_18px_42px_rgba(35,31,32,0.1)] backdrop-blur-xl md:px-5">
    <a class="focus-ring inline-flex items-center rounded-full" aria-label="Home" href="/">
      <Image
        alt="The Filibusters"
        class="h-12 w-auto md:h-14"
        height="96"
        loading="eager"
        src={filibustersLogoText}
        width="320"
      />
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-2 rounded-full border border-black/8 bg-white/70 p-1.5 md:flex">
      {primaryNav.map((item) => (
        <a
          class="focus-ring rounded-full px-4 py-2 text-sm font-semibold tracking-[0.08em] text-[var(--color-ink)]/72 transition hover:bg-[var(--color-ink)] hover:text-white"
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <nav
    aria-label="Mobile quick actions"
    class="fixed bottom-4 left-1/2 z-40 flex w-[calc(100%-1.5rem)] max-w-sm -translate-x-1/2 items-center justify-between rounded-full border border-white/70 bg-white/86 px-3 py-2 shadow-[0_18px_42px_rgba(35,31,32,0.16)] backdrop-blur-xl md:hidden"
  >
    {primaryNav.map((item) => (
      <a
        aria-label={item.label}
        class="focus-ring inline-flex h-12 w-12 items-center justify-center rounded-full text-[var(--color-ink)]/78 transition hover:bg-[var(--color-ink)] hover:text-white"
        href={item.href}
      >
        <svg
          aria-hidden="true"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
          viewBox="0 0 24 24"
        >
          <path d={iconPaths[item.icon]} />
        </svg>
      </a>
    ))}
  </nav>
</header>
