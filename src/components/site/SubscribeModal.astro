---
import { subscribePage } from "../../data/subscribe";
import { siteMeta } from "../../data/site";

// The signup posts to /api/subscribe (server route → Kit). The legacy
// PUBLIC_COMMUNITY_FORM_ACTION env var is no longer required, but if it is
// set we keep using it as the form's `action` (graceful fallback if JS is
// disabled). When JS is on, the script intercepts submit and uses fetch().
const legacyFormAction = import.meta.env.PUBLIC_COMMUNITY_FORM_ACTION;
const formAction = legacyFormAction || "/api/subscribe";
const fallbackHref = `mailto:${siteMeta.contactEmail}?subject=Subscribe%20to%20The%20Filibusters`;
---

<div aria-hidden="true" class="subscribe-modal-shell" data-subscribe-modal hidden>
  <div class="subscribe-modal-backdrop" data-subscribe-close></div>

  <section
    aria-labelledby="subscribe-modal-title"
    aria-modal="true"
    class="subscribe-modal-dialog"
    data-subscribe-dialog
    role="dialog"
    tabindex="-1"
  >
    <button
      aria-label="Close subscribe form"
      class="subscribe-modal-close focus-ring"
      data-subscribe-close
      type="button"
    >
      <span aria-hidden="true">×</span>
    </button>

    <div class="subscribe-modal-content">
      <p class="subscribe-modal-eyebrow">{subscribePage.eyebrow}</p>
      <h2 class="display-face subscribe-modal-title" id="subscribe-modal-title">
        {subscribePage.title}
      </h2>
      <p class="subscribe-modal-copy">{subscribePage.description}</p>

      <ul class="subscribe-modal-promise">
        {subscribePage.promise.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <form
        class="subscribe-modal-form"
        action={formAction}
        method="POST"
        data-subscribe-form
        data-track-event="subscribe_submit"
        data-track-label="email-form"
        data-track-source="subscribe-modal"
      >
        <label class="subscribe-modal-label" for="subscribe-modal-email">
          {subscribePage.form.emailLabel}
        </label>
        <input
          class="subscribe-modal-input"
          id="subscribe-modal-email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
        <button class="focus-ring subscribe-modal-submit" type="submit" data-subscribe-submit>
          {subscribePage.form.submitLabel}
        </button>
        <p class="subscribe-modal-status" data-subscribe-status hidden role="status" aria-live="polite"></p>
        <p class="subscribe-modal-fallback-note">
          Trouble subscribing? <a href={fallbackHref}>Email the band</a> and we will add you manually.
        </p>
      </form>
    </div>
  </section>
</div>

<script>
  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "textarea:not([disabled])",
    "[tabindex]:not([tabindex='-1'])"
  ].join(",");

  document.querySelectorAll("[data-subscribe-modal]").forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const dialog = root.querySelector("[data-subscribe-dialog]");
    const openers = document.querySelectorAll("[data-subscribe-open]");
    const closeControls = root.querySelectorAll("[data-subscribe-close]");

    let opener: HTMLElement | null = null;

    const closeModal = () => {
      root.classList.remove("is-visible");
      root.setAttribute("aria-hidden", "true");
      document.body.classList.remove("follow-prompt-open");
      root.hidden = true;

      if (opener instanceof HTMLElement && opener.isConnected) {
        opener.focus();
      }
    };

    const trapFocus = (event: KeyboardEvent) => {
      if (event.key !== "Tab" || !root.classList.contains("is-visible") || !(dialog instanceof HTMLElement)) {
        return;
      }

      const focusable = Array.from(dialog.querySelectorAll(focusableSelector)).filter(
        (node): node is HTMLElement =>
          node instanceof HTMLElement &&
          !node.hasAttribute("disabled") &&
          node.getAttribute("aria-hidden") !== "true"
      );

      if (focusable.length === 0) {
        event.preventDefault();
        dialog.focus();
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const active = document.activeElement;

      if (event.shiftKey && active === first) {
        event.preventDefault();
        last.focus();
        return;
      }

      if (!event.shiftKey && active === last) {
        event.preventDefault();
        first.focus();
      }
    };

    const openModal = (trigger: Element | null) => {
      const active = document.activeElement;
      opener = trigger instanceof HTMLElement ? trigger : active instanceof HTMLElement ? active : null;
      root.hidden = false;
      root.classList.add("is-visible");
      root.setAttribute("aria-hidden", "false");
      document.body.classList.add("follow-prompt-open");

      if (dialog instanceof HTMLElement) {
        const firstFocusable = dialog.querySelector(focusableSelector);

        if (firstFocusable instanceof HTMLElement) {
          firstFocusable.focus();
          return;
        }

        dialog.focus();
      }
    };

    openers.forEach((node) => {
      node.addEventListener("click", (event) => {
        event.preventDefault();
        openModal(node);
      });
    });

    closeControls.forEach((node) => {
      node.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && root.classList.contains("is-visible")) {
        closeModal();
        return;
      }

      trapFocus(event);
    });
  });
</script>

<script>
  // Progressive enhancement: intercept signup form submits, POST to
  // /api/subscribe via fetch, and show inline success/error. Falls back to
  // the form's native action if JS fails (the form still has action="...").
  const forms = document.querySelectorAll<HTMLFormElement>("[data-subscribe-form]");

  forms.forEach((form) => {
    // Status element may live inside the form (modal) or as a sibling
    // (homepage section). Prefer same-parent sibling, fall back to descendant.
    const status =
      form.parentElement?.querySelector<HTMLElement>(":scope > [data-subscribe-status]") ||
      form.querySelector<HTMLElement>("[data-subscribe-status]");
    const submit = form.querySelector<HTMLButtonElement>("[data-subscribe-submit]");
    const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');

    const setStatus = (message: string, tone: "success" | "error" | "info") => {
      if (!status) return;
      status.hidden = false;
      status.textContent = message;
      status.dataset.tone = tone;
    };

    form.addEventListener("submit", async (event) => {
      // Only intercept when the form is wired to our API route. If a legacy
      // external action (Mailchimp/Buttondown/etc.) is still set, let the
      // browser handle it natively.
      const action = form.getAttribute("action") || "";
      if (!action.startsWith("/api/subscribe")) return;

      event.preventDefault();

      const email = (emailInput?.value || "").trim();
      if (!email) {
        setStatus("Please enter your email address.", "error");
        emailInput?.focus();
        return;
      }

      if (submit) {
        submit.disabled = true;
        submit.dataset.originalLabel = submit.dataset.originalLabel || submit.textContent || "";
        submit.textContent = "Subscribing...";
      }
      setStatus("Subscribing...", "info");

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "content-type": "application/json", accept: "application/json" },
          body: JSON.stringify({ email })
        });

        let body: { ok?: boolean; error?: string } = {};
        try {
          body = await res.json();
        } catch {
          // non-JSON response
        }

        if (res.ok && body.ok) {
          setStatus("You're in. Check your inbox to confirm.", "success");
          form.reset();
        } else {
          setStatus(
            body.error || "Something went wrong. Please try again shortly.",
            "error"
          );
        }
      } catch {
        setStatus("Network error. Please try again shortly.", "error");
      } finally {
        if (submit) {
          submit.disabled = false;
          submit.textContent = submit.dataset.originalLabel || "Subscribe";
        }
      }
    });
  });
</script>
