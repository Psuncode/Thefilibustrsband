---
import { footerContent, iconPaths, secondaryRoutes, siteMeta, socialLinks } from "../../data/site";
---

<footer class="mobile-nav-offset border-t border-black/10 bg-ink text-white">
  <div class="mx-auto max-w-6xl px-4 pt-9 md:px-6 md:pt-12">
    <aside
      aria-label="Band summary"
      class="max-w-[60ch] rounded-lg border-l-4 border-pink bg-white/5 px-5 py-4 text-[0.95rem] leading-6 text-white/82"
    >
      <span class="mb-2 block text-[0.72rem] font-bold uppercase tracking-[0.18em] text-pink">
        Band summary
      </span>
      {siteMeta.canonicalParagraph}
    </aside>
  </div>
  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-9 md:grid-cols-[minmax(0,1fr)_minmax(0,0.82fr)] md:gap-8 md:px-6 md:py-12">
    <div class="space-y-4">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-yellow">{footerContent.eyebrow}</p>
        <p class="display-face mt-3 max-w-[9ch] text-[2.2rem] uppercase leading-[0.95] tracking-[-0.03em] md:max-w-xl md:text-5xl">
          {footerContent.title}
        </p>
      </div>
      <p class="max-w-lg text-sm leading-6 text-white/75 md:leading-7">
        {footerContent.description}
      </p>
      <p class="max-w-lg text-sm leading-6 text-white/58">
        {footerContent.geoDescription}
      </p>
      <a
        class="focus-ring inline-flex min-h-11 w-fit items-center justify-center rounded-full bg-yellow px-5 py-3 text-sm font-bold uppercase tracking-[0.14em] text-ink transition hover:bg-white"
        href={`mailto:${siteMeta.contactEmail}`}
        data-track-event="booking_email_click"
        data-track-label="footer-email"
        data-track-source="footer"
      >
        {siteMeta.contactEmail}
      </a>
    </div>
    <div class="space-y-5 rounded-[1.75rem] border border-white/10 bg-white/5 p-4 md:space-y-6 md:rounded-[2rem] md:p-6">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-white/60">Connect</p>
        <div class="mt-3 flex flex-wrap gap-2.5 md:mt-4 md:gap-3">
          {socialLinks.map((social) => (
            <a
              aria-label={social.label}
              class="focus-ring inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white transition hover:border-pink hover:bg-white/10 hover:text-yellow md:h-12 md:w-12"
              href={social.href}
              rel="me noreferrer"
              target="_blank"
              title={social.label}
            >
              <svg
                aria-hidden="true"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.8"
                viewBox="0 0 24 24"
              >
                <path d={iconPaths[social.icon]} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-white/60">Explore</p>
        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2.5 md:mt-4 md:gap-x-5 md:gap-y-3">
          {secondaryRoutes.map((route) =>
            route.kind === "modal" ? (
              <button
                class="focus-ring text-sm font-semibold text-white/82 transition hover:text-yellow"
                data-subscribe-open
                data-track-event="subscribe_open"
                data-track-label={`footer-link-${route.label.toLowerCase().replace(/\s+/g, "-")}`}
                data-track-source="footer"
                type="button"
              >
                {route.label}
              </button>
            ) : (
              <a
                class="focus-ring text-sm font-semibold text-white/82 transition hover:text-yellow"
                href={route.href}
              >
                {route.label}
              </a>
            )
          )}
        </div>
      </div>
      <div class="border-t border-white/10 pt-3 md:pt-4">
        <button
          class="focus-ring inline-flex min-h-11 w-full items-center justify-center rounded-full border border-white/12 bg-white/5 px-4 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:border-pink hover:text-yellow sm:w-auto"
          data-subscribe-open
          data-track-event="subscribe_open"
          data-track-label="footer-cta"
          data-track-source="footer"
          type="button"
        >
          Join the email list
        </button>
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs font-semibold text-white/55">
          <button
            class="focus-ring min-h-11 text-left transition hover:text-yellow"
            data-follow-prompt-open
            type="button"
          >
            Follow the band
          </button>
          <a class="focus-ring transition hover:text-yellow" href="/privacy">
            Privacy
          </a>
          <a class="focus-ring transition hover:text-yellow" href="/contact">
            Contact
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll("[data-follow-prompt-open]").forEach((node) => {
    node.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("filibusters:follow-prompt-open", { detail: { force: true } }));
    });
  });
</script>
