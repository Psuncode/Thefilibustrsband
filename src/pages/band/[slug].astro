---
import { Image } from "astro:assets";
import Footer from "../../components/site/Footer.astro";
import Header from "../../components/site/Header.astro";
import { bandMembers } from "../../data/bandMembers";
import { buildBreadcrumbList } from "../../lib/seo/breadcrumb";
import { siteEntityIds, siteMeta } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return bandMembers.map((member) => ({
    params: { slug: member.slug }
  }));
}

const { slug } = Astro.params;
const member = bandMembers.find((entry) => entry.slug === slug);

if (!member) {
  throw new Error(`Unknown band member slug: ${slug}`);
}

const pageUrl = new URL(`/band/${member.slug}`, Astro.site).href;
const imageUrl = new URL(member.image.src, Astro.site).href;

const seoTitle = `${member.name} — ${member.role}, The Filibusters`;
const seoDescription = `${member.name} is the ${member.role.toLowerCase()} of The Filibusters, the Provo, Utah alt rock band. Meet the band, hear the music, and catch a live show.`;

const personStructuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: member.name,
  jobTitle: member.role,
  url: pageUrl,
  image: imageUrl,
  memberOf: {
    "@id": siteEntityIds.musicGroup
  }
};

const breadcrumbStructuredData = buildBreadcrumbList(Astro.site!.toString(), [
  { name: "Home", path: "/" },
  { name: "About", path: "/about" },
  { name: member.name, path: `/band/${member.slug}` }
]);
---

<BaseLayout
  title={`${seoTitle} | ${siteMeta.title}`}
  description={seoDescription}
  ogImage={member.image.src}
  ogType="website"
  structuredData={[personStructuredData, breadcrumbStructuredData]}
>
  <Header />
  <main id="main-content" tabindex="-1" class="mobile-nav-offset overflow-x-clip bg-white">
    <section class="border-b border-black/10">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:px-6 md:py-16 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
        <article class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-pink">
            The Filibusters
          </p>
          <h1 class="display-face mt-3 text-4xl uppercase leading-[0.92] tracking-[-0.04em] md:text-6xl">
            {member.name}
          </h1>
          <p class="mt-5 text-sm font-semibold uppercase tracking-[0.14em] text-muted">
            {member.role}
          </p>
          <div class="mt-8 space-y-4">
            {member.bio.map((paragraph) => (
              <p class="text-base leading-7 text-ink/85 md:text-lg">{paragraph}</p>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-ink px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-pink"
              href="/listen"
            >
              Listen
            </a>
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
              href="/shows"
            >
              See shows
            </a>
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
              href="/about"
            >
              Meet the band
            </a>
          </div>
          <p class="mt-6 text-sm font-semibold uppercase tracking-[0.12em] text-muted">
            <a class="focus-ring underline-offset-4 hover:text-pink hover:underline" href="/">
              Back to home
            </a>
          </p>
        </article>

        <aside class="poster-frame overflow-hidden rounded-[2rem]">
          <Image
            src={member.image}
            alt={member.imageAlt}
            width="1280"
            height="1600"
            decoding="async"
            class="aspect-[4/5] w-full object-cover object-center"
            widths={[720, 1080]}
            sizes="(max-width: 1023px) 100vw, 40vw"
          />
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
