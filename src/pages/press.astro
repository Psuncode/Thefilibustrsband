---
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import { pressPage } from "../data/press";
import { buildPageId, buildPageUrl, siteEntityIds, siteMeta, siteRoutes, specialRoutes } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const pressStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": buildPageId(siteRoutes.press.path),
  name: `Press Room | ${siteMeta.title}`,
  url: buildPageUrl(siteRoutes.press.path),
  description: "Press-ready bio, approved assets, quotes, and contact information for The Filibusters.",
  isPartOf: {
    "@id": siteEntityIds.website
  },
  about: {
    "@id": siteEntityIds.musicGroup
  },
  dateModified: "2026-05-21"
} as const;

const pressMailto = (() => {
  const subject = encodeURIComponent("Filibusters press inquiry");
  const body = encodeURIComponent(
    [
      "Hi Filibusters,",
      "",
      "I'm [your name] from [outlet]. I'm working on [story angle] and would love to:",
      "  - request press assets / photos",
      "  - confirm a quote / fact",
      "  - schedule a quick interview by [date]",
      "",
      "Anything else useful: [link to outlet, deadline, etc.]",
      "",
      "Thanks,",
      "[name]"
    ].join("\n")
  );
  return `mailto:${pressPage.contactEmail}?subject=${subject}&body=${body}`;
})();
---

<BaseLayout
  title={`Press Room | ${siteMeta.title}`}
  description="Press-ready bio, approved assets, quotes, and contact information for The Filibusters."
  structuredData={pressStructuredData}
>
  <Header />
  <main id="main-content" class="mobile-nav-offset overflow-x-clip bg-paper-soft">
    <section class="border-b border-black/10 bg-white">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-pink md:text-sm">
          {pressPage.eyebrow}
        </p>
        <h1 class="display-face mt-3 max-w-4xl text-[2.35rem] uppercase leading-[0.92] tracking-[-0.04em] md:text-6xl">
          {pressPage.title}
        </h1>
        <p class="mt-3 max-w-3xl text-[0.98rem] leading-6 text-ink/76 md:mt-4 md:text-lg md:leading-7">
          {pressPage.description}
        </p>
      </div>
    </section>

    <section>
      <div class="mx-auto grid max-w-6xl gap-4 px-4 py-10 md:gap-6 md:px-6 md:py-16 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
        <article class="poster-frame rounded-[1.75rem] p-5 md:p-7">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-pink">Short bio</p>
          <p class="mt-4 text-base leading-7 text-ink/85 md:text-lg" data-copy-target="short-bio">{pressPage.shortBio}</p>
          <button
            type="button"
            class="focus-ring mt-4 inline-flex items-center gap-2 rounded-full border border-black/12 bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-ink transition hover:border-pink hover:text-pink"
            data-copy-button="short-bio"
          >
            <span data-copy-label>Copy short bio</span>
          </button>

          <p class="mt-8 text-xs font-bold uppercase tracking-[0.2em] text-pink">Long bio</p>
          <div class="mt-4 space-y-4" data-copy-target="long-bio">
            {pressPage.longBio.map((paragraph) => (
              <p class="text-base leading-7 text-ink/85">{paragraph}</p>
            ))}
          </div>
          <button
            type="button"
            class="focus-ring mt-4 inline-flex items-center gap-2 rounded-full border border-black/12 bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-ink transition hover:border-pink hover:text-pink"
            data-copy-button="long-bio"
          >
            <span data-copy-label>Copy long bio</span>
          </button>
        </article>

        <article class="poster-frame rounded-[1.75rem] p-5 md:p-7">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-pink">Press assets</p>
          <div class="mt-5 grid gap-3">
            {pressPage.approvedAssets.map((asset) => (
              <a
                class="focus-ring flex items-center justify-between gap-4 rounded-[1.25rem] border border-black/8 bg-white px-4 py-4 text-sm font-semibold text-ink transition hover:border-pink hover:text-pink"
                href={asset.href}
                target="_blank"
                rel="noreferrer"
              >
                <span>
                  <span class="block uppercase tracking-[0.12em]">{asset.label}</span>
                  <span class="mt-1 block text-xs font-medium normal-case leading-5 text-muted">
                    {asset.description}
                  </span>
                </span>
                <span aria-hidden="true">-&gt;</span>
              </a>
            ))}
          </div>

          <p class="mt-8 text-xs font-bold uppercase tracking-[0.2em] text-pink">Video</p>
          <a
            class="focus-ring mt-4 inline-flex min-h-11 items-center justify-center rounded-full bg-ink px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-pink"
            href={pressPage.videoLink}
            rel="noreferrer"
            target="_blank"
          >
            Watch on YouTube
          </a>

          <p class="mt-8 text-xs font-bold uppercase tracking-[0.2em] text-pink">Press contact</p>
          <a
            class="focus-ring mt-4 inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
            href={`mailto:${pressPage.contactEmail}`}
            data-track-event="booking_email_click"
            data-track-label="press-contact"
            data-track-source="press-page"
          >
            {pressPage.contactLabel}: {pressPage.contactEmail}
          </a>
          <p class="mt-4 text-xs leading-5 text-ink/58">
            For structured factual lookup, see the{" "}
            <a
              class="underline decoration-black/20 underline-offset-4 transition hover:text-pink"
              href={specialRoutes.aiPressKit.href}
              data-track-event="ai_press_kit_click"
              data-track-label="press-copy-link"
              data-track-source="press-page"
            >
              {specialRoutes.aiPressKit.label}
            </a>
            .
          </p>
        </article>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <div class="poster-frame rounded-[1.75rem] p-5 md:p-7">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-pink">Approved pull quotes</p>
          <div class="mt-5 grid gap-3 md:grid-cols-3 md:gap-4">
            {pressPage.quotes.map((quote) => (
              <blockquote class="rounded-[1.25rem] border border-black/8 bg-paper-soft px-4 py-5 text-sm font-semibold leading-6 text-ink/82">
                “{quote}”
              </blockquote>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-black/10 bg-paper-soft">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <div class="poster-frame rounded-[1.75rem] bg-white p-5 md:p-7">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-pink">Press contact</p>
          <h2 class="display-face mt-3 text-[1.75rem] uppercase leading-[0.95] tracking-[-0.03em] md:text-4xl">
            Need anything else? Email lands directly with the band.
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-ink/85 md:text-lg">
            Drop a line with your outlet, deadline, and what you're after. We aim to reply within 48 hours.
          </p>
          <div class="mt-6 flex flex-col gap-2.5 sm:flex-row sm:flex-wrap">
            <a
              class="focus-ring inline-flex min-h-12 items-center justify-center rounded-full bg-ink px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-pink"
              href={pressMailto}
            >
              Email {pressPage.contactEmail}
            </a>
            <a
              class="focus-ring inline-flex min-h-12 items-center justify-center rounded-full border border-black/12 bg-white px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
              href={`mailto:${pressPage.contactEmail}`}
            >
              Plain email (no template)
            </a>
            <a
              class="focus-ring inline-flex min-h-12 items-center justify-center rounded-full border border-black/12 bg-white px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] text-ink transition hover:border-pink hover:text-pink"
              href={siteRoutes.epk.path}
            >
              Booking / EPK
            </a>
          </div>
          <p class="mt-10 text-xs font-semibold uppercase tracking-[0.14em] text-muted">
            Page last updated May 2026
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
<script>
  const FEEDBACK_DURATION_MS = 1600;

  const fallbackCopy = (text: string): boolean => {
    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.opacity = "0";
    document.body.appendChild(textarea);
    textarea.select();

    let ok = false;
    try {
      ok = document.execCommand("copy");
    } catch {
      ok = false;
    }
    textarea.remove();
    return ok;
  };

  const copyText = async (text: string): Promise<boolean> => {
    if (navigator.clipboard && window.isSecureContext) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        // fall through to fallback
      }
    }
    return fallbackCopy(text);
  };

  document.querySelectorAll<HTMLButtonElement>("[data-copy-button]").forEach((button) => {
    const targetKey = button.getAttribute("data-copy-button");
    if (!targetKey) return;
    const target = document.querySelector<HTMLElement>(`[data-copy-target="${targetKey}"]`);
    if (!target) return;
    const label = button.querySelector<HTMLElement>("[data-copy-label]");
    if (!label) return;
    const originalLabel = label.textContent;

    button.addEventListener("click", async () => {
      const text = (target.innerText || "").trim();
      if (!text) return;

      const ok = await copyText(text);
      label.textContent = ok ? "Copied!" : "Press Cmd/Ctrl + C";

      window.setTimeout(() => {
        label.textContent = originalLabel;
      }, FEEDBACK_DURATION_MS);
    });
  });
</script>
</BaseLayout>
