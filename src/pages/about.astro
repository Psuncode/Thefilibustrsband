---
import { Image } from "astro:assets";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { aboutPage } from "../data/about";
import { siteMeta } from "../data/site";

const listenCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/listen" || label.toLowerCase().includes("listen")
);
const showsCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/shows" || label.toLowerCase().includes("show")
);
const communityCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/community" || label.toLowerCase().includes("update")
);
const contactCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/contact" || label.toLowerCase().includes("contact")
);

const heroCtas = [listenCta, contactCta].filter(Boolean);
const footerCtas = [listenCta, showsCta, communityCta, contactCta].filter(Boolean);
---

<BaseLayout
  title={`About | ${siteMeta.title}`}
  description={aboutPage.definition.intro}
>
  <Header />
  <main id="main-content" class="mobile-nav-offset overflow-x-clip">
    <section class="border-b border-black/10">
      <div class="mx-auto max-w-6xl px-4 py-12 md:px-6 md:py-16">
        <div class="max-w-4xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            {aboutPage.hero.eyebrow}
          </p>
          <h1 class="display-face mt-3 text-4xl uppercase leading-[0.92] tracking-[-0.04em] md:text-6xl">
            {aboutPage.hero.title}
          </h1>
          {aboutPage.hero.description.map((paragraph) => (
            <p class="mt-5 max-w-3xl text-base leading-7 text-[var(--color-ink)]/78 md:text-lg md:leading-8">
              {paragraph}
            </p>
          ))}
          <div class="mt-8 flex flex-wrap gap-3">
            {heroCtas.map((cta, index) => (
              <a
                class:list={[
                  "focus-ring inline-flex min-h-12 items-center justify-center rounded-full px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] transition",
                  index === 0
                    ? "bg-[var(--color-pink)] text-white hover:bg-[var(--color-ink)]"
                    : "border border-black/12 bg-white text-[var(--color-ink)] hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
                ]}
                href={cta.href}
              >
                {cta.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-paper-soft)]">
      <div class="mx-auto grid max-w-6xl gap-6 px-4 py-12 md:px-6 md:py-16 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
        <div class="poster-frame rounded-[2rem] p-6 md:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            {aboutPage.definition.title}
          </p>
          <p class="mt-4 text-lg font-semibold leading-8 text-[var(--color-ink)]">
            {aboutPage.definition.intro}
          </p>
          <p class="mt-4 text-base leading-7 text-[var(--color-ink)]/74">
            {aboutPage.definition.body}
          </p>
        </div>
        <div class="max-w-3xl lg:hidden">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            {aboutPage.factsSection.eyebrow}
          </p>
        </div>
        <dl class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          {aboutPage.quickFacts.map((fact) => (
            <div class="poster-frame rounded-[1.5rem] p-5">
              <dt class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
                {fact.label}
              </dt>
              <dd class="mt-3 text-lg font-semibold leading-7 text-[var(--color-ink)]">
                {fact.value}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-6xl px-4 py-12 md:px-6 md:py-16">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            Meet the band
          </p>
          <h2 class="display-face mt-3 text-3xl uppercase leading-[0.95] tracking-[-0.03em] md:text-5xl">
            The people making the noise.
          </h2>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {aboutPage.members.map((member) => (
            <article class="poster-frame overflow-hidden rounded-[1.75rem]">
              <Image
                src={member.photo}
                alt={member.alt}
                class="aspect-[4/5] w-full object-cover object-center"
                widths={[480, 720]}
                sizes="(max-width: 639px) 100vw, (max-width: 1279px) 50vw, 25vw"
              />
              <div class="p-5">
                <h3 class="text-xl font-black uppercase leading-tight text-[var(--color-ink)]">
                  {member.name}
                </h3>
                <p class="mt-2 text-sm uppercase tracking-[0.12em] text-[var(--color-muted)]">
                  {member.role}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-ink)] text-white">
      <div class="mx-auto max-w-6xl px-4 py-12 md:px-6 md:py-16">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-yellow)]">
            {aboutPage.story.title}
          </p>
          {aboutPage.story.paragraphs.map((paragraph) => (
            <p class="mt-4 text-base leading-7 text-white/82 md:text-lg md:leading-8">
              {paragraph}
            </p>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-paper-soft)]">
      <div class="mx-auto grid max-w-6xl gap-6 px-4 py-12 md:px-6 md:py-16 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
        <div class="poster-frame rounded-[1.75rem] p-6">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            Similar artists
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {aboutPage.similarArtists.map((artist) => (
              <span class="rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-semibold text-[var(--color-ink)]/82">
                {artist}
              </span>
            ))}
          </div>
        </div>

        <div class="poster-frame rounded-[1.75rem] p-6 md:p-7">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">FAQ</h2>
          <dl class="mt-5 space-y-5">
            {aboutPage.faq.map((item) => (
              <div class="border-b border-black/8 pb-5 last:border-b-0 last:pb-0">
                <dt class="text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)]">
                  {item.question}
                </dt>
                <dd class="mt-2 max-w-2xl text-sm leading-6 text-[var(--color-ink)]/74 md:text-base">
                  {item.answer}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <section class="border-t border-black/10 bg-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-5 px-4 py-12 md:px-6 md:py-16 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            {aboutPage.ctaSection.eyebrow}
          </p>
          <h2 class="display-face mt-3 text-3xl uppercase leading-[0.95] tracking-[-0.03em] md:text-5xl">
            {aboutPage.ctaSection.title}
          </h2>
          <p class="mt-4 text-base leading-7 text-[var(--color-ink)]/74 md:text-lg">
            {aboutPage.ctaSection.description}
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap lg:justify-end">
          {footerCtas.map((cta, index) => (
            <a
              class:list={[
                "focus-ring inline-flex min-h-12 items-center justify-center rounded-full px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] transition",
                index === 0
                  ? "bg-[var(--color-ink)] text-white hover:bg-[var(--color-pink)]"
                  : "border border-black/12 bg-[var(--color-paper-soft)] text-[var(--color-ink)] hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
              ]}
              href={cta.href}
            >
              {cta.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
