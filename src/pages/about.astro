---
import { Image } from "astro:assets";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { aboutPage } from "../data/about";
import { siteEntityIds, siteMeta } from "../data/site";
import heroBand from "../assets/images/hero-band.jpg";

const listenCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/listen" || label.toLowerCase().includes("listen")
);
const showsCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/shows" || label.toLowerCase().includes("show")
);
const communityCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/community" || label.toLowerCase().includes("update")
);
const contactCta = aboutPage.ctas.find(({ href, label }) =>
  href === "/contact" || label.toLowerCase().includes("contact")
);

const heroCtas = [listenCta, contactCta].filter(Boolean);
const footerCtas = [listenCta, showsCta, communityCta, contactCta].filter(Boolean);

const aboutStructuredData = {
  "@type": "AboutPage",
  "@id": siteEntityIds.aboutPage,
  name: "About The Filibusters",
  url: Astro.url.href,
  description: aboutPage.definition.intro,
  about: {
    "@id": siteEntityIds.musicGroup
  },
  isPartOf: {
    "@id": siteEntityIds.website
  }
} as const;
---

<BaseLayout
  title={`About | ${siteMeta.title}`}
  description={aboutPage.definition.intro}
  structuredData={aboutStructuredData}
>
  <Header />
  <main id="main-content" class="mobile-nav-offset overflow-x-clip bg-[linear-gradient(180deg,#fffdf8_0%,#fff7ef_18rem,var(--color-paper-soft)_44rem,var(--color-paper)_100%)]">
    <section class="border-b border-black/10 bg-white/72">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <div class="max-w-4xl">
          <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
            {aboutPage.hero.eyebrow}
          </p>
          <h1 class="display-face mt-3 max-w-[11ch] text-[2.55rem] uppercase leading-[0.92] tracking-[-0.045em] md:max-w-none md:text-6xl">
            {aboutPage.hero.title}
          </h1>
          {aboutPage.hero.description.map((paragraph) => (
            <p class="mt-4 max-w-3xl text-[0.98rem] leading-6 text-[var(--color-ink)]/78 md:mt-5 md:text-lg md:leading-8">
              {paragraph}
            </p>
          ))}
          <div class="mt-7 grid gap-3 sm:flex sm:flex-wrap">
            {heroCtas.map((cta, index) => (
              <a
                class:list={[
                  "focus-ring inline-flex min-h-12 w-full items-center justify-center rounded-full px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] transition sm:w-auto",
                  index === 0
                    ? "bg-[var(--color-pink)] text-white hover:bg-[var(--color-ink)]"
                    : "border border-black/12 bg-white text-[var(--color-ink)] hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
                ]}
                href={cta.href}
              >
                {cta.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-paper-soft)]">
      <div class="mx-auto grid max-w-6xl gap-4 px-4 py-10 md:gap-6 md:px-6 md:py-16 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
        <div class="poster-frame rounded-[1.75rem] p-5 md:rounded-[2rem] md:p-8">
          <div class="grid gap-5 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-start">
            <div>
              <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
                {aboutPage.definition.title}
              </p>
              <div class="mt-4 overflow-hidden rounded-[1.4rem] border border-black/8 bg-white p-2.5 lg:hidden">
                <Image
                  src={heroBand}
                  alt="The Filibusters together in a band photo."
                  class="aspect-[16/10] w-full rounded-[1rem] object-cover object-center"
                  widths={[720, 1080, 1440]}
                  sizes="100vw"
                />
              </div>
              <p class="mt-4 text-[1.05rem] font-semibold leading-7 text-[var(--color-ink)] md:text-lg md:leading-8">
                {aboutPage.definition.intro}
              </p>
              <p class="mt-4 text-[0.96rem] leading-6 text-[var(--color-ink)]/74 md:text-base md:leading-7">
                {aboutPage.definition.body}
              </p>
            </div>
            <div class="hidden overflow-hidden rounded-[1.5rem] border border-black/8 bg-white p-3 lg:block">
              <Image
                src={heroBand}
                alt="The Filibusters together in a band photo."
                class="aspect-[16/12] w-full rounded-[1.1rem] object-cover object-center"
                widths={[720, 1080, 1440]}
                sizes="(max-width: 1023px) 100vw, 38vw"
              />
            </div>
          </div>
        </div>
        <div class="space-y-3">
          <div class="max-w-3xl">
            <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
              {aboutPage.factsSection.eyebrow}
            </p>
          </div>
          <dl class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {aboutPage.quickFacts.map((fact) => (
            <div class="poster-frame rounded-[1.35rem] p-4 md:rounded-[1.5rem] md:p-5">
              <dt class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
                {fact.label}
              </dt>
              <dd class="mt-3 text-base font-semibold leading-6 text-[var(--color-ink)] md:text-lg md:leading-7">
                {fact.value}
              </dd>
            </div>
          ))}
          </dl>
        </div>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <div class="max-w-3xl">
          <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
            Meet the band
          </p>
          <h2 class="display-face mt-3 max-w-[10ch] text-[2rem] uppercase leading-[0.95] tracking-[-0.03em] md:max-w-none md:text-5xl">
            The people making the noise.
          </h2>
        </div>
        <div class="mt-6 grid gap-3 md:mt-8 md:gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {aboutPage.members.map((member) => (
            <article class="poster-frame overflow-hidden rounded-[1.5rem] sm:rounded-[1.75rem] sm:block">
              <Image
                src={member.photo}
                alt={member.alt}
                class="aspect-[5/4] w-full object-cover object-center sm:aspect-[4/5]"
                widths={[480, 720]}
                sizes="(max-width: 639px) 100vw, (max-width: 1279px) 50vw, 25vw"
              />
              <div class="p-4 md:p-5">
                <h3 class="text-lg font-black uppercase leading-tight text-[var(--color-ink)] md:text-xl">
                  {member.name}
                </h3>
                <p class="mt-2 text-sm uppercase tracking-[0.12em] text-[var(--color-muted)]">
                  {member.role}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-ink)] text-white">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <div class="max-w-3xl">
          <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-yellow)] md:text-sm">
            {aboutPage.story.title}
          </p>
          {aboutPage.story.paragraphs.map((paragraph) => (
            <p class="mt-4 text-[0.98rem] leading-6 text-white/82 md:text-lg md:leading-8">
              {paragraph}
            </p>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-paper-soft)]">
      <div class="mx-auto grid max-w-6xl gap-4 px-4 py-10 md:gap-6 md:px-6 md:py-16 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
        <div class="poster-frame order-2 rounded-[1.5rem] p-5 md:order-1 md:rounded-[1.75rem] md:p-6">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
            Similar artists
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {aboutPage.similarArtists.map((artist) => (
              <span class="rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-semibold text-[var(--color-ink)]/82">
                {artist}
              </span>
            ))}
          </div>
        </div>

        <div class="poster-frame order-1 rounded-[1.5rem] p-5 md:order-2 md:rounded-[1.75rem] md:p-7">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">FAQ</h2>
          <dl class="mt-4 space-y-4 md:mt-5 md:space-y-5">
            {aboutPage.faq.map((item) => (
              <div class="border-b border-black/8 pb-4 last:border-b-0 last:pb-0 md:pb-5">
                <dt class="text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)]">
                  {item.question}
                </dt>
                <dd class="mt-2 max-w-2xl text-sm leading-6 text-[var(--color-ink)]/74 md:text-base">
                  {item.answer}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <section class="border-t border-black/10 bg-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-5 px-4 py-10 md:px-6 md:py-16 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
            {aboutPage.ctaSection.eyebrow}
          </p>
          <h2 class="display-face mt-3 max-w-[10ch] text-[2rem] uppercase leading-[0.95] tracking-[-0.03em] md:max-w-none md:text-5xl">
            {aboutPage.ctaSection.title}
          </h2>
          <p class="mt-4 text-[0.98rem] leading-6 text-[var(--color-ink)]/74 md:text-lg md:leading-7">
            {aboutPage.ctaSection.description}
          </p>
        </div>

        <div class="grid gap-3 sm:flex sm:flex-row sm:flex-wrap lg:justify-end">
          {footerCtas.map((cta, index) => (
            <a
              class:list={[
                "focus-ring inline-flex min-h-12 w-full items-center justify-center rounded-full px-6 py-3 text-sm font-bold uppercase tracking-[0.12em] transition sm:w-auto",
                index === 0
                  ? "bg-[var(--color-ink)] text-white hover:bg-[var(--color-pink)]"
                  : "border border-black/12 bg-[var(--color-paper-soft)] text-[var(--color-ink)] hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
              ]}
              href={cta.href}
            >
              {cta.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
