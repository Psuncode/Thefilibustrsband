---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/site/Footer.astro";
import Header from "../../components/site/Header.astro";
import { getPastShows, getUpcomingShows } from "../../lib/shows/data";
import { siteMeta, siteRoutes, specialRoutes } from "../../data/site";

const shows = await getUpcomingShows();
const pastShows = await getPastShows();

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric"
});
---

<BaseLayout
  title={`Shows | ${siteMeta.title}`}
  description="See upcoming The Filibusters live dates, venue details, and ticket links for Provo, Utah and nearby shows."
>
  <Header />
  <main id="main-content" class="mobile-nav-offset overflow-x-clip bg-[var(--color-paper-soft)]">
    <section class="border-b border-black/10 bg-white">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">Shows</p>
        <h1 class="display-face mt-3 text-[2.35rem] uppercase leading-[0.92] tracking-[-0.04em] md:text-6xl">
          Upcoming dates worth showing up for.
        </h1>
        <p class="mt-3 max-w-3xl text-[0.98rem] leading-6 text-[var(--color-ink)]/76 md:mt-4 md:text-lg md:leading-7">
          Find Filibusters live shows, check venue details, and grab tickets for dates in Provo, Utah and beyond.
        </p>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
        {shows.length > 0 ? (
          <div class="grid gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
            {shows.map((show) => (
              <article class="poster-frame overflow-hidden rounded-[1.75rem]">
                {show.flyerUrl ? (
                  <a class="block" href={`/shows/${show.slug}`}>
                    <img
                      alt={`${show.title} event image`}
                      class="aspect-[4/3] w-full object-cover object-center"
                      loading="lazy"
                      src={show.flyerUrl}
                    />
                  </a>
                ) : null}
                <div class="p-4 md:p-5">
                  <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
                    {formatter.format(new Date(show.startsAt))}
                  </p>
                  <h2 class="mt-4 text-2xl font-black uppercase leading-tight text-[var(--color-ink)]">
                    <a class="focus-ring rounded-sm" href={`/shows/${show.slug}`}>
                      {show.title}
                    </a>
                  </h2>
                  <p class="mt-3 text-sm uppercase tracking-[0.12em] text-[var(--color-muted)]">
                    {show.venue} · {show.city}, {show.state}
                  </p>
                  {show.summary ? (
                    <p class="mt-4 text-sm leading-6 text-[var(--color-ink)]/74">{show.summary}</p>
                  ) : null}
                  <div class="mt-5 grid gap-2.5 sm:flex sm:gap-3 md:mt-6">
                    <a
                      class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-[var(--color-pink)]"
                      href={`/shows/${show.slug}`}
                    >
                      View details
                    </a>
                    {show.ticketUrl ? (
                      <a
                        class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)] transition hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
                        href={show.ticketUrl}
                        rel="noreferrer"
                        target="_blank"
                        data-track-event="ticket_click"
                        data-track-label={show.slug}
                        data-track-source="shows-index"
                      >
                        Tickets
                      </a>
                    ) : null}
                  </div>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <article class="poster-frame rounded-[1.75rem] p-6">
            <h2 class="text-2xl font-black uppercase text-[var(--color-ink)]">
              No upcoming shows announced yet
            </h2>
            <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-ink)]/74">
              Check back soon or stay close to the band for the next live date.
            </p>
          </article>
        )}

        <article class="poster-frame mt-4 rounded-[1.75rem] p-5 md:mt-6 md:p-7">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">Keep moving</p>
          <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-ink)]/78">
            If you want the backstory before the next show, head to About. If you want the other side of the route, keep listening.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white transition hover:bg-[var(--color-pink)]"
              href={siteRoutes.about.path}
            >
              About
            </a>
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)] transition hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
              href={siteRoutes.listen.path}
            >
              Listen
            </a>
            <a
              class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)] transition hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
              href={specialRoutes.localDiscovery.href}
            >
              {specialRoutes.localDiscovery.label}
            </a>
          </div>
        </article>
      </div>
    </section>

    {pastShows.length > 0 ? (
      <section class="border-t border-black/10 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-16">
          <p class="text-[0.82rem] font-bold uppercase tracking-[0.2em] text-[var(--color-pink)] md:text-sm">
            Past shows
          </p>
          <h2 class="display-face mt-3 text-[2rem] uppercase leading-[0.95] tracking-[-0.03em] md:text-5xl">
            Recent dates that already happened.
          </h2>
          <div class="mt-8 grid gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
            {pastShows.map((show) => (
              <article class="poster-frame overflow-hidden rounded-[1.75rem] opacity-95">
                {show.flyerUrl ? (
                  <a class="block" href={`/shows/${show.slug}`}>
                    <img
                      alt={`${show.title} event image`}
                      class="aspect-[4/3] w-full object-cover object-center saturate-[0.82]"
                      loading="lazy"
                      src={show.flyerUrl}
                    />
                  </a>
                ) : null}
                <div class="p-4 md:p-5">
                  <div class="flex flex-wrap items-center gap-3">
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-pink)]">
                      {formatter.format(new Date(show.startsAt))}
                    </p>
                    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-muted)]">
                      Past show
                    </p>
                  </div>
                  <h2 class="mt-4 text-2xl font-black uppercase leading-tight text-[var(--color-ink)]">
                    <a class="focus-ring rounded-sm" href={`/shows/${show.slug}`}>
                      {show.title}
                    </a>
                  </h2>
                  <p class="mt-3 text-sm uppercase tracking-[0.12em] text-[var(--color-muted)]">
                    {show.venue} · {show.city}, {show.state}
                  </p>
                  {show.summary ? (
                    <p class="mt-4 text-sm leading-6 text-[var(--color-ink)]/74">{show.summary}</p>
                  ) : null}
                  <div class="mt-5">
                    <a
                      class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-black/12 bg-white px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-[var(--color-ink)] transition hover:border-[var(--color-pink)] hover:text-[var(--color-pink)]"
                      href={`/shows/${show.slug}`}
                    >
                      View recap
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ) : null}
  </main>
  <Footer />
</BaseLayout>
