---
import Analytics from "@vercel/analytics/astro";
import heroBand from "../assets/images/hero-band.jpg";
import { buildMusicGroupSchema, siteMeta } from "../data/site";
import { upcomingShows } from "../data/shows";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(heroBand.src, Astro.site);
const musicGroupStructuredData = buildMusicGroupSchema({ image: ogImage.href });
const structuredData = [
  musicGroupStructuredData,
  ...upcomingShows.map((show) => ({
    "@context": "https://schema.org",
    "@type": "Event",
    name: `${siteMeta.title} at ${show.venue}`,
    startDate: show.date,
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    image: [ogImage.href],
    performer: {
      "@type": "MusicGroup",
      name: siteMeta.title,
      url: siteMeta.url
    },
    location: {
      "@type": "Place",
      name: show.venue,
      address: show.city
    }
  }))
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl.href} />
    <link rel="llms" href={`${siteMeta.url}/llms.txt`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteMeta.title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1500" />
    <meta property="og:image:alt" content={`${siteMeta.title} band photo`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <a class="focus-ring sr-only focus:not-sr-only" href="#main-content">Skip to content</a>
    <slot />
    <Analytics />
  </body>
</html>
